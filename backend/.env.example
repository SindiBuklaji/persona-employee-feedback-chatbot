# OpenAI Configuration
OPENAI_API_KEY=sk-your-actual-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Database Configuration
# Local development:
DATABASE_URL=sqlite:///./thesis_chatbot.db

# Railway/Production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname
# Copy this from your Railway PostgreSQL service settings

# Study Parameters
MIN_TURNS=3
MAX_TURNS=5
TEMPERATURE=1.0
TOP_K_RETRIEVAL=3

# CORS Configuration
# Local development:
ALLOWED_ORIGINS=http://localhost:8501

# Railway/Production (update with your frontend URL):
# ALLOWED_ORIGINS=https://frontend-ui-xxxxx.railway.app

# Feature Flags
DEBUG=false
RETRIEVAL_ENABLED=true
RETRIEVAL_USE_EMBEDDINGS=true
RETRIEVAL_LOGGING_ENABLED=true

# Admin Token (for CSV exports)
# In production, generate a random token:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# In development, leave empty to skip authentication
ADMIN_TOKEN=
